# ============================================
# 知因AI 环境变量配置
# 复制此文件为 .env 并根据实际环境修改
# ============================================

# ===== 服务端口 =====
SERVER_PORT=8080
VITE_PORT=5173
NODE_ENV=development

# ===== OpenClaw 配置 =====
OPENCLAW_AGENT=math-assistant
OPENCLAW_TIMEOUT=120000

# OpenClaw 可执行文件路径（Linux/Mac 默认 openclaw，从 PATH 查找）
# Windows 示例: C:\Users\xxx\AppData\Roaming\npm\openclaw.cmd
# Linux/Mac 示例: /usr/local/bin/openclaw 或直接用 openclaw（已加入 PATH）
OPENCLAW_BIN=openclaw

# ===== SQL Server 数据库配置 =====
# 如不配置 DB_HOST，服务将以无数据库模式运行（仅 API 代理）
DB_HOST=localhost
DB_PORT=1433
DB_NAME=zhiyin_ai
DB_USER=sa
DB_PASSWORD=your_password_here

# 连接池
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# SQL Server 选项
DB_ENCRYPT=false
DB_TRUST_CERT=true
DB_REQUEST_TIMEOUT=30000

# 数据库日志（true 开启 SQL 日志）
DB_LOGGING=false

# 时区
DB_TIMEZONE=+08:00

# ===== JWT 密钥（后续身份验证用）=====
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d
